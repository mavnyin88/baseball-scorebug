# MLB API base (override if proxying through a vendor later)
MLB_API_BASE=https://statsapi.mlb.com/api/v1

# Vercel KV — populated automatically when you link a KV store in Vercel
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Warmer auth — protects /api/internal/* routes. The same value must be sent
# as `Authorization: Bearer <CRON_SECRET>` by the external scheduler
# (cron-job.org). Generate with: `openssl rand -hex 32`
CRON_SECRET=
